### VARIABLES ADICIONALES NECESARIAS
#@accessToken = 716a6939ea3e1c1a95b6a877dc225f0b521daf0a39d4c71cee61e82cb6eb3e2e
#@asignacionId = 69b0d4fd97ead0d3edd7ee7d
#@pacienteId = 69b69b0c12e7a656d75470d4232

# ============================================
# 1. GUARDAR PROGRESO (PÚBLICO - DESDE JUEGO)
# ============================================
POST {{baseUrl}}/api/progress
Content-Type: application/json

{
    "token": "{{accessToken}}",
    "asignacionId": "{{asignacionId}}",
    "puntuacion": 85,
    "tiempoJugado": 180,
    "rondasCompletadas": 10,
    "rondasTotales": 10,
    "aciertos": 9,
    "errores": 1,
    "completado": true,
    "datosJuego": {
        "nivel": 1,
        "animalesIdentificados": ["perro", "gato", "vaca", "pato", "cerdo"],
        "tiempoPorRonda": [15, 18, 12, 20, 16, 14, 19, 17, 21, 18]
    },
    "dispositivo": "web",
    "navegador": "Chrome",
    "sistemaOperativo": "Windows 10"
}

### Respuesta esperada:
