POST {{baseUrl}}/api/games
Authorization: Bearer {{tokenProfesional}}
Content-Type: application/json

{
    "nombre": "Memoria de Palabras",
    "descripcion": "Juego de memoria con palabras y conceptos",
    "instrucciones": "Encuentra los pares de palabras iguales",
    "codigo": "MEMORIA_PALABRAS",
    "areaTerapeutica": "semantica",
    "nivelDificultad": "intermedio",
    "rangoEdad": {
        "min": 5,
        "max": 10
    },
    "objetivos": [
        "Mejorar memoria visual",
        "Reconocer palabras",
        "Asociar conceptos"
    ],
    "palabrasClave": ["memoria", "palabras", "concentración"],
    "duracionEstimada": 5,
    "numeroRondas": 1,
    "puntuacionMaxima": 100,
    "porcentajeAprobacion": 60,
    "thumbnail": "memoria-thumb.png",
    "urlJuego": "/games/html5/memoria/index.html",
    "publicado": true
}

