# ============================================
# FLUJO COMPLETO DE EJEMPLO
# ============================================

### Paso 1: Paciente obtiene sus juegos asignados
GET {{baseUrl}}/api/assignments/token/{{accessToken}}/games

### Paso 2: Paciente juega y envía resultados
POST {{baseUrl}}/api/progress
Content-Type: application/json

{
    "token": "{{accessToken}}",
    "asignacionId": "{{asignacionId}}",
    "puntuacion": 90,
    "tiempoJugado": 165,
    "rondasCompletadas": 10,
    "rondasTotales": 10,
    "aciertos": 9,
    "errores": 1,
    "completado": true,
    "datosJuego": {
        "dificultad": "medio",
        "sonidosReconocidos": ["perro", "gato", "vaca", "pato"]
    },
    "dispositivo": "mobile",
    "navegador": "Safari",
    "sistemaOperativo": "iOS 17"
}

### Paso 3: Tutor/Profesional ve el progreso
GET {{baseUrl}}/api/progress/patient/{{pacienteId}}
Authorization: Bearer {{token}}

### Paso 4: Ver evolución en el tiempo
GET {{baseUrl}}/api/progress/evolucion/{{pacienteId}}/{{juegoId}}?dias=7
Authorization: Bearer {{token}}

### ======================================================
### PASO 1: Obtener juegos del paciente con su token
GET {{baseUrl}}/api/assignments/token/{{accessToken}}/games

### Respuesta: Copia el asignacionId

### PASO 2: Guardar una sesión de juego
POST {{baseUrl}}/api/progress
Content-Type: application/json

{
    "token": "{{accessToken}}",
    "asignacionId": "PEGA_AQUI_EL_ASSIGNMENT_ID",
    "puntuacion": 85,
    "tiempoJugado": 180,
    "rondasCompletadas": 10,
    "rondasTotales": 10,
    "aciertos": 9,
    "errores": 1,
    "completado": true,
    "datosJuego": {
        "nivel": "medio",
        "animalesCorrectos": ["perro", "gato", "vaca"]
    },
    "dispositivo": "web"
}

