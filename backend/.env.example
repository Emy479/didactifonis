# ============================================
# DIDACTIFONIS - VARIABLES DE ENTORNO
# ============================================

# --------------------------------------------
# SERVER CONFIGURATION
# --------------------------------------------
PORT=3000
NODE_ENV=development

# --------------------------------------------
# DATABASE
# --------------------------------------------
# Local MongoDB
MONGODB_URI=mongodb://localhost:27017/didactifonis

# MongoDB Atlas (Producción)
# MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/didactifonis?retryWrites=true&w=majority

# --------------------------------------------
# JWT AUTHENTICATION
# --------------------------------------------
# IMPORTANTE: Cambiar en producción con un secreto largo y aleatorio
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=didactifonis-super-secreto-2026-cambiar-en-produccion

# --------------------------------------------
# CORS (Opcional)
# --------------------------------------------
# Lista de orígenes permitidos separados por coma
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://didactifonis.com

# --------------------------------------------
# SECURITY (Opcional)
# --------------------------------------------
# Rate Limiting
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=100

# --------------------------------------------
# LOGS (Opcional)
# --------------------------------------------
# LOG_LEVEL=info
# LOG_FILE=./logs/didactifonis.log

# --------------------------------------------
# EMAIL (Futuro)
# --------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@didactifonis.com

# --------------------------------------------
# STORAGE (Futuro)
# --------------------------------------------
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BUCKET_NAME=
# AWS_REGION=

# --------------------------------------------
# NOTAS
# --------------------------------------------
# 1. NO commitear este archivo con valores reales
# 2. Copiar como .env y configurar con valores reales
# 3. Agregar .env al .gitignore
# 4. En producción, usar variables de entorno del hosting
